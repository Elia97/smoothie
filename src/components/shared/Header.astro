---
const navItems = [
  { name: "Home", href: "/" },
  { name: "Manifesto", href: "/manifesto" },
  { name: "Portfolio", href: "/portfolio" },
  { name: "Contact", href: "/contact" },
];
---

<header
  id="main-header"
  data-hero-header
  class="fixed z-50 top-0 left-2 right-2 sm:left-8 sm:right-8 h-20 flex justify-between items-center px-6 py-3 pointer-events-none"
>
  <span
    class="inline-flex items-center text-xl font-bold bg-background tracking-wider pointer-events-auto p-2 pb-1 rounded-full"
    >Smoothie</span
  >

  <!-- Desktop nav -->
  <nav class="hidden lg:block bg-background pointer-events-auto rounded-full">
    <ul class="flex rounded-full">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="flex items-center p-3 pb-2 text-sm font-semibold tracking-wider transition-colors duration-150 hover:text-muted-foreground rounded-full"
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Mobile hamburger -->
  <button
    data-menu-toggle
    aria-label="Apri menu"
    aria-expanded="false"
    class="lg:hidden pointer-events-auto bg-white rounded-full p-2 flex flex-col justify-center items-center gap-1.5 w-10 h-10 cursor-pointer"
  >
    <span
      class="block w-5 h-0.5 bg-black rounded-full transition-transform duration-300 origin-center aria-expanded:rotate-45 aria-expanded:translate-y-0.5"
      data-line-top></span>
    <span
      class="block w-5 h-0.5 bg-black rounded-full transition-transform duration-300 origin-center aria-expanded:-rotate-45 aria-expanded:-translate-y-0.5"
      data-line-bottom></span>
  </button>
</header>

<!-- Mobile menu sheet -->
<div
  data-mobile-menu
  class="group fixed inset-0 z-50 pointer-events-none invisible data-open:pointer-events-auto data-open:visible lg:hidden"
>
  <!-- Backdrop -->
  <div
    data-menu-backdrop
    class="absolute inset-0 bg-black/0 transition-colors duration-300 ease-out group-data-open:bg-black/50 motion-reduce:transition-none"
  >
  </div>

  <!-- Sheet -->
  <nav
    data-menu-sheet
    class="absolute top-0 right-0 bottom-0 w-4/5 max-w-80
         bg-white rounded-l-2xl
         translate-x-full transition-transform duration-300 ease-out
         group-data-open:translate-x-0 motion-reduce:transition-none
         flex flex-col h-full"
  >
    <!-- Header -->
    <div class="flex justify-end p-2">
      <button
        data-menu-close
        aria-label="Chiudi menu"
        class="bg-gray-100 rounded-full p-2 flex flex-col justify-center items-center w-10 h-10 cursor-pointer"
      >
        <span
          class="block w-5 h-0.5 bg-black rounded-full rotate-45 translate-y-px"
        ></span>
        <span
          class="block w-5 h-0.5 bg-black rounded-full -rotate-45 -translate-y-px"
        ></span>
      </button>
    </div>

    <!-- Navigation -->
    <ul class="flex flex-col px-8 pt-4">
      <li>
        <a
          href="/"
          data-menu-link
          class="block py-3 text-2xl font-bold text-black tracking-tight transition-colors duration-150 hover:text-gray-500"
        >
          Home
        </a>
      </li>
      <li>
        <a
          href="/manifesto"
          data-menu-link
          class="block py-3 text-2xl font-bold text-black tracking-tight transition-colors duration-150 hover:text-gray-500"
        >
          Manifesto
        </a>
      </li>
      <li>
        <a
          href="/portfolio"
          data-menu-link
          class="block py-3 text-2xl font-bold text-black tracking-tight transition-colors duration-150 hover:text-gray-500"
        >
          Portfolio
        </a>
      </li>
      <li>
        <a
          href="/contact"
          data-menu-link
          class="block py-3 text-2xl font-bold text-black tracking-tight transition-colors duration-150 hover:text-gray-500"
        >
          Contact
        </a>
      </li>
    </ul>

    <!-- Social (Footer) -->
    <div class="mt-auto px-8 pb-4">
      <p
        class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3"
      >
        Follow us
      </p>
      <ul class="flex flex-col gap-1">
        <li>
          <a
            href="https://www.instagram.com/smoothie.agency"
            target="_blank"
            rel="noopener noreferrer"
            class="block py-1.5 text-sm text-gray-500 transition-colors duration-150 hover:text-black"
          >
            Instagram
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com/smoothie.agency"
            target="_blank"
            rel="noopener noreferrer"
            class="block py-1.5 text-sm text-gray-500 transition-colors duration-150 hover:text-black"
          >
            Facebook
          </a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/company/smoothie-agency"
            target="_blank"
            rel="noopener noreferrer"
            class="block py-1.5 text-sm text-gray-500 transition-colors duration-150 hover:text-black"
          >
            LinkedIn
          </a>
        </li>
      </ul>
    </div>
  </nav>
</div>

<script>
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const toggle = document.querySelector<HTMLElement>("[data-menu-toggle]");
  const backdrop = document.querySelector<HTMLElement>("[data-menu-backdrop]");
  const close = document.querySelector<HTMLElement>("[data-menu-close]");
  const links = document.querySelectorAll<HTMLElement>("[data-menu-link]");

  function open(): void {
    if (!menu || !toggle) return;
    menu.setAttribute("data-open", "");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function shut(): void {
    if (!menu || !toggle) return;
    menu.removeAttribute("data-open");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", () => {
    menu?.hasAttribute("data-open") ? shut() : open();
  });
  backdrop?.addEventListener("click", shut);
  close?.addEventListener("click", shut);
  links.forEach((link) => link.addEventListener("click", shut));
</script>
