---
const navItems = [
  { name: "Home", href: "/" },
  { name: "Manifesto", href: "/manifesto" },
  { name: "Portfolio", href: "/portfolio" },
  { name: "Contact", href: "/contact" },
];
---

<a
  href="#main-content"
  class="fixed z-9999 -top-full left-1/2 transform -translate-x-1/2 px-4 py-2 bg-background text-foreground rounded-full font-semibold focus:top-4 pointer-events-auto"
>
  Vai al contenuto principale
</a>

<header
  id="main-header"
  data-hero-header
  class="fixed z-50 top-0 left-2 right-2 sm:left-8 sm:right-8 h-20 flex justify-between items-center px-6 py-3 pointer-events-none"
>
  <span
    class="inline-flex items-center text-xl font-bold bg-background tracking-wider pointer-events-auto p-2 pb-1 rounded-full"
    >Smoothie</span
  >

  <!-- Desktop nav -->
  <nav class="hidden lg:block bg-background pointer-events-auto rounded-full">
    <ul class="flex rounded-full">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-label={item.name.toLowerCase()}
              class="flex items-center p-3 pb-2 text-sm font-semibold tracking-wider transition-colors duration-150 hover:text-muted-foreground rounded-full"
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Mobile hamburger -->
  <button
    data-menu-toggle
    aria-label="Apri menu"
    aria-expanded="false"
    class="lg:hidden pointer-events-auto bg-background rounded-full p-2 flex flex-col justify-center items-center gap-1.5 w-10 h-10 cursor-pointer"
  >
    <span aria-hidden="true" class="block w-5 h-0.5 bg-foreground rounded-full"
    ></span>
    <span aria-hidden="true" class="block w-5 h-0.5 bg-foreground rounded-full"
    ></span>
  </button>
</header>

<!-- Mobile menu sheet -->
<div
  data-mobile-menu
  class="group fixed inset-0 z-50 pointer-events-none invisible data-open:pointer-events-auto data-open:visible lg:hidden"
>
  <!-- Backdrop -->
  <div
    data-menu-backdrop
    class="absolute inset-0 bg-black/0 transition-colors duration-300 ease-out group-data-open:bg-black/50 motion-reduce:transition-none"
  >
  </div>

  <!-- Sheet -->
  <nav
    data-menu-sheet
    class="absolute top-0 right-0 bottom-0 w-3/4 max-w-80
         bg-background rounded-l-2xl
         translate-x-full transition-transform duration-300 ease-out
         group-data-open:translate-x-0 motion-reduce:transition-none
         flex flex-col h-full"
  >
    <!-- Header -->
    <div class="flex justify-end p-2">
      <button
        data-menu-close
        aria-label="Chiudi menu"
        class="bg-background rounded-full p-2 flex flex-col justify-center items-center w-10 h-10 cursor-pointer"
      >
        <span
          aria-hidden="true"
          class="block w-5 h-0.5 bg-foreground rounded-full rotate-45 translate-y-px"
        ></span>
        <span
          aria-hidden="true"
          class="block w-5 h-0.5 bg-foreground rounded-full -rotate-45 -translate-y-px"
        ></span>
      </button>
    </div>

    <!-- Navigation -->
    <ul
      class="flex flex-col px-8 pt-4 absolute top-1/2 transform -translate-y-1/2 uppercase"
    >
      {
        navItems.map((item, index) => (
          <li>
            <a
              href={item.href}
              data-menu-link
              class={`block py-3 text-3xl font-bold tracking-tight transition-colors duration-150 ${
                index === 1
                  ? "text-transparent bg-clip-text bg-linear-to-r from-rose-300 via-violet-500 to-sky-300 hover:from-rose-400 hover:via-violet-600 hover:to-sky-400"
                  : "hover:text-muted-foreground"
              }`}
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Social (Footer) -->
    <div class="mt-auto px-4 pb-2">
      <p
        class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2"
      >
        Follow us
      </p>
      <ul class="flex flex-col">
        <li>
          <a
            href="https://www.instagram.com/smoothie.agency"
            target="_blank"
            rel="noopener noreferrer"
            class="block py-1 text-sm text-muted-foreground transition-colors duration-150 hover:text-foreground"
          >
            Instagram
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com/smoothie.agency"
            target="_blank"
            rel="noopener noreferrer"
            class="block py-1 text-sm text-muted-foreground transition-colors duration-150 hover:text-foreground"
          >
            Facebook
          </a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/company/smoothie-agency"
            target="_blank"
            rel="noopener noreferrer"
            class="block py-1 text-sm text-muted-foreground transition-colors duration-150 hover:text-foreground"
          >
            LinkedIn
          </a>
        </li>
      </ul>
    </div>
  </nav>
</div>

<script>
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const sheet = document.querySelector<HTMLElement>("[data-menu-sheet]");
  const toggle = document.querySelector<HTMLElement>("[data-menu-toggle]");
  const backdrop = document.querySelector<HTMLElement>("[data-menu-backdrop]");
  const close = document.querySelector<HTMLElement>("[data-menu-close]");
  const links = document.querySelectorAll<HTMLElement>("[data-menu-link]");

  function open(): void {
    if (!menu || !toggle) return;
    menu.setAttribute("data-open", "");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
    const firstLink = menu.querySelector<HTMLElement>("[data-menu-link]");
    firstLink?.focus();
  }

  function shut(): void {
    if (!menu || !toggle) return;
    menu.removeAttribute("data-open");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    toggle.focus();
  }

  function trapFocus(e: KeyboardEvent): void {
    if (e.key !== "Tab" || !sheet || !menu?.hasAttribute("data-open")) return;
    const focusable = sheet.querySelectorAll<HTMLElement>(
      'a[href], button, [tabindex]:not([tabindex="-1"])',
    );
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  toggle?.addEventListener("click", () => {
    menu?.hasAttribute("data-open") ? shut() : open();
  });
  backdrop?.addEventListener("click", shut);
  close?.addEventListener("click", shut);
  links.forEach((link) => link.addEventListener("click", shut));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menu?.hasAttribute("data-open")) {
      shut();
    }
    trapFocus(e);
  });
</script>
