<footer
  id="main-footer"
  class="sticky bottom-0 z-0 bg-foreground text-background"
>
  <div class="p-8">
    <!-- Top: contenuto principale -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-8 mb-8">
      <!-- Sinistra: titolo, newsletter, contatto -->
      <div class="flex flex-col gap-6">
        <div>
          <h3
            class="text-3xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-2"
          >
            Let's talk
          </h3>
          <p class="max-w-md sm:text-lg text-muted leading-relaxed">
            Let's make your brand unforgettable
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <form class="flex flex-col sm:flex-row gap-2 max-w-md sm:text-nowrap">
            <label for="newsletter-email" class="sr-only">Indirizzo email</label>
            <input
              id="newsletter-email"
              type="email"
              placeholder="Email..."
              required
              class="pl-4 pr-2 pt-2 pb-1 bg-input border rounded-full text-foreground placeholder-muted-foreground focus:outline-none focus:border-border/50 transition-colors"
            />
            <button
              type="submit"
              class="px-4 pt-2 pb-1 bg-input text-foreground rounded-full font-medium hover:bg-input/70 transition-colors cursor-pointer"
            >
              Subscribe to our newsletter
            </button>
          </form>
          <a
            href="mailto:contact@smoothiecommunicate.com"
            class="text-muted hover:text-background transition-colors text-sm"
          >
            contact@smoothiecommunicate.com
          </a>
        </div>
      </div>

      <!-- Destra: due colonne sedi -->
      <div class="grid grid-cols-2 gap-4 lg:pt-2">
        <div>
          <h4
            class="font-semibold text-sm uppercase tracking-wider mb-4 text-muted"
          >
            Padova
          </h4>
          <address class="not-italic text-xs leading-relaxed">
            Largo Europa, 20<br />
            35137 (PD)<br />
            +93 0424066395
          </address>
        </div>
        <div>
          <h4
            class="font-semibold text-sm uppercase tracking-wider mb-4 text-muted"
          >
            Milano
          </h4>
          <address class="not-italic text-xs leading-relaxed">
            Largo Europa, 20<br />
            35137 (PD)<br />
            +93 0424066395
          </address>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="border-t pt-4 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <small class="text-muted">
        &copy; {new Date().getFullYear()} Smoothie. Tutti i diritti riservati.
      </small>
    </div>
  </div>
</footer>

<script>
  function setFooterMargin(): void {
    const footer = document.getElementById("main-footer");
    const main = document.querySelector("main");
    if (!footer || !main) return;
    main.style.marginBottom = `${footer.offsetHeight}px`;
  }

  setFooterMargin();
  window.addEventListener("resize", setFooterMargin);
</script>
