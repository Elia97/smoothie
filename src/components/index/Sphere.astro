---

---

<section id="sphere-section" class="relative h-[600vh]">
  <div
    class="sticky top-0 h-screen flex items-center justify-center overflow-hidden"
  >
    <!-- Fase 1: Badge + 4 titoli -->
    <div
      data-sphere-titles
      class="relative z-10 flex flex-col items-center gap-6 text-center px-4"
    >
      <span
        data-sphere-badge
        class="text-sm sm:text-base border w-fit px-3 py-1 rounded-full mb-4"
      >
        WHAT WE DO
      </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        CONSULTANCY
      </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        CREATIVE
      </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        COMMUNICATE
      </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        PERFORMANCE
      </span>
    </div>

    <!-- Sfera -->
    <div
      data-sphere-orb
      class="absolute rounded-full pointer-events-none"
      style="
        width: 120vw;
        height: 120vw;
        background: radial-gradient(circle, rgba(139,92,246,0.6) 0%, rgba(59,130,246,0.5) 60%, rgba(59,130,246,0.4) 100%);
        box-shadow: 0 0 120px 60px rgba(255,255,255,0.3), 0 0 240px 120px rgba(255,255,255,0.15);
      "
    >
    </div>

    <!-- Contenuto dentro la sfera -->
    <div
      data-sphere-inner
      class="absolute z-20 flex flex-col items-center gap-4 text-center px-4"
    >
      <span
        class="text-sm sm:text-base border border-white/40 w-fit px-3 py-1 rounded-full text-white"
      >
        OUR MISSION
      </span>
      <h2
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight text-white"
      >
        Guidare la crescita <br /> delle aziende con <br /> innovazione, creatività
        <br /> e tecnologia
      </h2>
    </div>

    <!-- Titolo finale + CTA (parte 3, specchiata) -->
    <div
      data-sphere-cta
      class="absolute z-10 flex flex-col items-center gap-6 text-center px-4"
    >
      <p class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight">
        Ready to shake things up?
      </p>
      <a
        href="#"
        class="inline-block px-8 py-2 bg-black text-white rounded-full text-lg font-medium hover:bg-gray-800 transition-colors"
      >
        CONTACT US
      </a>
    </div>
  </div>
</section>

<script>
  import {
    initGSAP,
    gsap,
    createContext,
    prefersReducedMotion,
  } from "../../motion/engine/gsap-core";
  import { ScrollTrigger } from "../../motion/engine/gsap-core";
  import { DURATION, EASE } from "../../motion/presets";

  initGSAP();

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      setupSphere();
    });
  });

  function setupSphere(): void {
    const section = document.querySelector<HTMLElement>("#sphere-section");
    if (!section) return;

    const reduced = prefersReducedMotion();
    const titlesWrap = section.querySelector<HTMLElement>(
      "[data-sphere-titles]",
    );
    const badge = section.querySelector<HTMLElement>("[data-sphere-badge]");
    const titles = section.querySelectorAll<HTMLElement>("[data-sphere-keyword]");
    const orb = section.querySelector<HTMLElement>("[data-sphere-orb]");
    const inner = section.querySelector<HTMLElement>("[data-sphere-inner]");
    const cta = section.querySelector<HTMLElement>("[data-sphere-cta]");

    if (!titlesWrap || !badge || !titles.length || !orb || !inner || !cta)
      return;

    createContext(section, () => {
      const dur = reduced ? 0.15 : DURATION.normal;
      const ease = reduced ? EASE.linear : EASE.smooth;

      // Calcolo posizioni sfera basate sul viewport
      const vh = window.innerHeight;
      const orbSize = orb.offsetHeight; // 250vw in px
      const orbRadius = orbSize / 2;

      // Posizione iniziale: solo il polo della sfera visibile in fondo allo schermo
      // Centro sfera sotto il viewport, con ~3% del diametro visibile sopra il bordo inferiore
      const peekAmount = orbSize * 0.03;
      const orbStartY = vh / 2 + orbRadius - peekAmount;

      // Posizione centrale: sfera centrata nel viewport
      const orbCenterY = 0;

      // Posizione finale (specchiata): fondo della sfera visibile in cima allo schermo
      const orbEndY = -(vh / 2 + orbRadius - peekAmount);

      // Stato iniziale
      gsap.set(badge, { autoAlpha: 1 }); // badge sempre visibile
      gsap.set(titles, { autoAlpha: 0, y: 40 });
      gsap.set(orb, { y: orbStartY, rotation: 0 });
      gsap.set(inner, { autoAlpha: 0, y: 30 });
      gsap.set(cta, { autoAlpha: 0, y: 30 });

      const tl = gsap.timeline();

      // ═══════════════════════════════════════════
      // PARTE 1: Badge + titoli + cima sfera in basso
      // ═══════════════════════════════════════════

      // Titoli appaiono uno dopo l'altro — stagger largo per snap visibile
      const titleStagger = dur * 2;
      titles.forEach((title, i) => {
        tl.to(
          title,
          {
            autoAlpha: 1,
            y: 0,
            duration: dur,
            ease: EASE.snap,
          },
          i * titleStagger,
        );
      });

      // Sfera ruota leggermente mentre i titoli appaiono
      const titlePhaseDur = (titles.length - 1) * titleStagger + dur;
      tl.to(
        orb,
        {
          rotation: 45,
          duration: titlePhaseDur,
          ease: EASE.linear,
        },
        0,
      );

      // Titoli e badge svaniscono
      const fadeOutStart = titlePhaseDur + dur * 0.5;
      tl.to(
        titlesWrap,
        {
          autoAlpha: 0,
          y: -40,
          duration: dur,
          ease,
        },
        fadeOutStart,
      );

      // ═══════════════════════════════════════════
      // PARTE 2: Sfera sale al centro, contenuto interno
      // ═══════════════════════════════════════════

      // Sfera sale al centro del viewport
      const riseSart = fadeOutStart;
      tl.to(
        orb,
        {
          y: orbCenterY,
          rotation: 180,
          duration: dur * 4,
          ease: EASE.inOut,
        },
        riseSart,
      );

      // Contenuto interno appare quando la sfera è centrata
      const innerStart = riseSart + dur * 3;
      tl.to(
        inner,
        {
          autoAlpha: 1,
          y: 0,
          duration: dur,
          ease,
        },
        innerStart,
      );

      // Contenuto interno svanisce
      const innerEnd = innerStart + dur * 2.5;
      tl.to(
        inner,
        {
          autoAlpha: 0,
          y: -30,
          duration: dur,
          ease,
        },
        innerEnd,
      );

      // ═══════════════════════════════════════════
      // PARTE 3: Sfera esce verso l'alto, CTA
      // (specchiata rispetto a parte 1)
      // ═══════════════════════════════════════════

      // Sfera esce verso l'alto — fondo visibile in cima allo schermo
      tl.to(
        orb,
        {
          y: orbEndY,
          rotation: 360,
          duration: dur * 4,
          ease: EASE.inOut,
        },
        innerEnd,
      );

      // CTA appare quando la sfera raggiunge la posizione finale (polo sud in alto)
      tl.to(
        cta,
        {
          autoAlpha: 1,
          y: 0,
          duration: dur,
          ease,
        },
        innerEnd + dur * 4 - dur,
      );

      // Calcola i punti di snap normalizzati per ogni titolo
      const totalDur = tl.duration();
      const titleSnapPoints = Array.from(titles).map((_, i) => {
        // Punto in cui il titolo è completamente visibile
        const titleEnd = i * titleStagger + dur;
        return titleEnd / totalDur;
      });
      // Aggiungi lo 0 (inizio) e il punto dopo il fade out dei titoli
      const allSnapPoints = [0, ...titleSnapPoints, fadeOutStart / totalDur];
      const titlePhaseEnd = (fadeOutStart + dur) / totalDur;

      ScrollTrigger.create({
        trigger: section,
        animation: tl,
        start: "top top",
        end: "bottom bottom",
        scrub: reduced ? false : 1,
        invalidateOnRefresh: true,
        snap: {
          snapTo: (progress: number) => {
            // Snap solo durante la fase titoli
            if (progress < titlePhaseEnd) {
              return allSnapPoints.reduce((prev, curr) =>
                Math.abs(curr - progress) < Math.abs(prev - progress) ? curr : prev
              );
            }
            return progress;
          },
          duration: 0.4,
          ease: "power2.inOut",
        },
      });
    });
  }
</script>
