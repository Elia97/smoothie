---

---

<section id="dark-section" class="relative h-[200vh]">
  <div
    data-dark-sticky
    class="sticky top-0 h-screen flex flex-col items-center justify-center gap-12 md:gap-16 overflow-hidden px-4"
  >
    <!-- Background overlay animated from transparent to black -->
    <div
      data-dark-bg
      class="absolute inset-0 bg-black pointer-events-none"
      style="opacity: 0;"
    >
    </div>

    <div class="relative z-10 max-w-md mx-auto text-center">
      <h2
        data-dark-text
        class="text-3xl sm:text-4xl lg:text-6xl text-center font-bold tracking-tight mb-4 md:mb-6"
      >
        "Lorem ipsum lorem ipsum"
      </h2>
      <a
        data-dark-btn
        href="#"
        class="inline-block px-8 py-2 bg-black text-white rounded-full text-lg font-medium transition-colors"
        >EXPLORE MORE</a
      >
    </div>
  </div>
</section>

<script>
  import {
    initGSAP,
    gsap,
    createContext,
    prefersReducedMotion,
  } from "../../motion/engine/gsap-core";
  import { createScrollAnimation } from "../../motion/engine/scroll-engine";
  import { DURATION, EASE } from "../../motion/presets";

  initGSAP();

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      setupDark();
    });
  });

  function setupDark(): void {
    const section = document.querySelector<HTMLElement>("#dark-section");
    if (!section) return;

    const reduced = prefersReducedMotion();
    const bg = section.querySelector<HTMLElement>("[data-dark-bg]");
    const text = section.querySelector<HTMLElement>("[data-dark-text]");
    const btn = section.querySelector<HTMLElement>("[data-dark-btn]");
    if (!bg || !text || !btn) return;

    createContext(section, () => {
      const dur = reduced ? 0.15 : DURATION.normal;

      // Testo sempre visibile — parte nero, diventa bianco
      gsap.set(text, { autoAlpha: 1 });
      gsap.set(btn, { autoAlpha: 1 });

      const tl = gsap.timeline();

      // Fase 1: sfondo nero, testo da nero a bianco, bottone si inverte, header si inverte
      tl.to(
        bg,
        {
          opacity: 1,
          duration: dur,
          ease: EASE.smooth,
        },
        0,
      );

      tl.to(
        text,
        {
          color: "#ffffff",
          duration: dur,
          ease: EASE.smooth,
        },
        0,
      );

      tl.to(
        btn,
        {
          backgroundColor: "#ffffff",
          color: "#000000",
          duration: dur,
          ease: EASE.smooth,
        },
        0,
      );

      // Fase 2: tutto torna normale
      const holdEnd = tl.duration() + 0.5;

      tl.to(
        bg,
        {
          opacity: 0,
          duration: dur,
          ease: EASE.smooth,
        },
        holdEnd,
      );

      tl.to(
        text,
        {
          color: "#000000",
          duration: dur,
          ease: EASE.smooth,
        },
        holdEnd,
      );

      tl.to(
        btn,
        {
          backgroundColor: "#000000",
          color: "#ffffff",
          duration: dur,
          ease: EASE.smooth,
        },
        holdEnd,
      );

      createScrollAnimation({
        trigger: section,
        animation: tl,
        start: "top top",
        end: "bottom bottom",
        scrub: reduced ? false : 1,
        pin: false,
      });
    });
  }
</script>
