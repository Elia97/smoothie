---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Smoothie">
  <section
    class="min-h-screen flex flex-col items-center justify-center gap-6 px-4 text-center"
  >
    <h1 class="text-7xl sm:text-9xl font-bold tracking-tighter">404</h1>
    <p class="text-lg text-gray-600 max-w-md">
      La pagina che stai cercando non esiste o è stata spostata.
    </p>
    <a
      href="/"
      class="inline-block px-8 py-3 bg-black text-white rounded-full text-base font-medium hover:bg-gray-800 transition-colors"
    >
      Torna alla home
    </a>
  </section>
</BaseLayout>
