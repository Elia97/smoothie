---
import MarqueeTrack from "../../components/ui/MarqueeTrack.astro";
import { Image } from "astro:assets";
import image1 from "../../assets/1_q80.webp";
import image2 from "../../assets/2_q80.webp";
import image3 from "../../assets/3_q80.webp";
import image4 from "../../assets/4_q80.webp";
import image5 from "../../assets/5_q80.webp";
import image6 from "../../assets/6_q80.webp";
import image7 from "../../assets/7_q80.webp";
import image8 from "../../assets/8_q80.webp";
import image9 from "../../assets/9_q80.webp";
import image10 from "../../assets/10_q80.webp";
import image11 from "../../assets/11_q80.webp";
import image12 from "../../assets/12_q80.webp";
---

<section
  id="gallery"
  class="min-h-screen flex flex-col justify-center gap-12 md:gap-16 overflow-hidden"
>
  <!-- Testo centrato, schiacciato in alto -->
  <div
    data-motion="fade-in"
    class="grid md:grid-cols-2 gap-8 container mx-auto items-center px-8 pt-12 md:pt-20"
  >
    <h2
      class="text-2xl sm:text-4xl lg:text-5xl font-bold tracking-tight"
      aria-label="La passione per il Prosecco dal cuore di Valdobbiadene"
    >
      La passione per il Prosecco dal cuore di Valdobbiadene
    </h2>
    <p class="max-w-xl sm:text-lg text-muted-foreground leading-relaxed">
      Un'azienda che custodisce il sapere della tradizione e lo trasforma in
      eccellenza. Dai vigneti alle bollicine, Cantine Vedova racconta
      l'autenticità del territorio con uno stile raffinato, sostenuto da
      un'identità visiva che abbiamo curato per rispecchiare la qualità del
      prodotto e della tradizione.
    </p>
  </div>

  <!-- Carosello marquee -->
  <div class="relative pb-4">
    <MarqueeTrack duration="40s" gap="1rem" class="items-center">
      <!-- Set 1 -->
      <div class="shrink-0 w-60 aspect-9/16 rounded-2xl overflow-hidden">
        <Image
          src={image1}
          alt="Cantine Vedova — prodotto Prosecco 1"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-square rounded-2xl overflow-hidden">
        <Image
          src={image2}
          alt="Cantine Vedova — dettaglio prodotto 2"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-9/16 rounded-2xl overflow-hidden">
        <Image
          src={image3}
          alt="Cantine Vedova — dettaglio prodotto 3"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-square rounded-2xl overflow-hidden">
        <Image
          src={image4}
          alt="Cantine Vedova — vigneto Valdobbiadene 4"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-9/16 rounded-2xl overflow-hidden">
        <Image
          src={image5}
          alt="Cantine Vedova — dettaglio prodotto 5"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-square rounded-2xl overflow-hidden">
        <Image
          src={image6}
          alt="Cantine Vedova — packaging 6"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-9/16 rounded-2xl overflow-hidden">
        <Image
          src={image7}
          alt="Cantine Vedova — prodotto Prosecco 7"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-square rounded-2xl overflow-hidden">
        <Image
          src={image8}
          alt="Cantine Vedova — dettaglio prodotto 8"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-9/16 rounded-2xl overflow-hidden">
        <Image
          src={image9}
          alt="Cantine Vedova — dettaglio prodotto 9"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-square rounded-2xl overflow-hidden">
        <Image
          src={image10}
          alt="Cantine Vedova — vigneto Valdobbiadene 10"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-9/16 rounded-2xl overflow-hidden">
        <Image
          src={image11}
          alt="Cantine Vedova — dettaglio prodotto 11"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-square rounded-2xl overflow-hidden">
        <Image
          src={image12}
          alt="Cantine Vedova — packaging 12"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <!-- Set 2 (duplicato per loop continuo) -->
      <div class="shrink-0 w-60 aspect-9/16 rounded-2xl overflow-hidden">
        <Image
          src={image1}
          alt="Cantine Vedova — prodotto Prosecco 1"
          loading="lazy"
          width={480}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="shrink-0 w-60 aspect-square rounded-2xl overflow-hidden">
