<section
  data-motion-cursor-follow
  class="relative min-h-screen flex flex-col items-center justify-center gap-6 px-4 overflow-hidden"
>
  <!-- Cursor-follow sphere -->
  <div
    data-cursor-target
    class="absolute w-175 h-175 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(139,92,246,0.6) 0%, rgba(59,130,246,0.5) 60%, rgba(59,130,246,0.4) 100%); box-shadow: 0 0 80px 40px rgba(255,255,255,0.3), 0 0 160px 80px rgba(255,255,255,0.15); z-index: 0;"
  >
  </div>

  <h1
    data-hero-title
    class="relative z-10 text-3xl sm:text-5xl lg:text-6xl font-bold text-center leading-snug tracking-tight"
  >
    <span data-type-text>Siamo il giusto </span><i
      data-type-word
      class="font-thin">mix</i
    >
    <br />
    <span data-type-text> che ridefinisce</span>
    <br />
    <span data-type-text>i confini</span>
    <br />
    <span data-type-text> del tuo </span><i data-type-word class="font-thin"
      >brand</i
    >
  </h1>

  <span data-hero-scroll-hint class="absolute bottom-4">Scroll to explore</span>
</section>

<script>
  import { setupHero } from "./hero.motion";
  setupHero();
</script>
