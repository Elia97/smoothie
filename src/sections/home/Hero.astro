---
import { Image } from "astro:assets";
import sferaImage from "../../assets/sfera.webp";
---

<section
  id="hero"
  data-motion-cursor-follow
  class="relative min-h-screen flex flex-col items-center justify-center gap-6 px-4 overflow-x-clip"
>
  <!-- Cursor-follow sphere -->
  <div data-hero-sphere-exit class="absolute size-200 pointer-events-none">
    <Image
      data-cursor-target
      src={sferaImage}
      alt="Sfera"
      width={800}
      loading="eager"
      class="w-full h-full rounded-full"
    />
  </div>

  <h1
    data-hero-title
    class="relative z-10 text-3xl sm:text-5xl lg:text-6xl font-bold text-center leading-snug tracking-tight"
  >
    <span data-type-text>Siamo il giusto </span><i
      data-type-word
      class="font-display font-thin">mix</i
    >
    <br />
    <span data-type-text> che ridefinisce</span>
    <span data-type-text>i confini</span>
    <br />
    <span data-type-text> del tuo </span><i
      data-type-word
      class="font-display font-thin">brand</i
    >
  </h1>

  <span data-hero-scroll-hint class="absolute bottom-4 sm:text-lg"
    >Scroll to <i class="font-display font-thin">explore</i></span
  >
</section>

<script>
  import { setupHero } from "./hero.motion";
  setupHero();
</script>
