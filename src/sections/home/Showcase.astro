---

---

<section id="showcase" class="relative min-h-screen md:h-[300vh]">
  <!-- ═══════════════════════════════════════════ -->
  <!-- MOBILE: layout statico con animazioni dichiarative -->
  <!-- ═══════════════════════════════════════════ -->
  <div
    class="md:hidden flex flex-col items-center justify-center min-h-screen gap-8 px-4"
  >
    <div
      data-motion="scale-in"
      class="w-full max-w-sm aspect-video rounded-2xl bg-rose-400/60"
    >
    </div>
    <div class="text-center">
      <h2
        data-motion="fade-in"
        class="text-3xl sm:text-4xl font-bold tracking-tight mb-8"
      >
        Elevate<br /> your brand with <br /> flavorful touch
      </h2>
      <a
        href="#"
        data-motion="fade-in"
        data-motion-delay="0.15"
        class="inline-block px-8 py-2 bg-black text-white rounded-full text-lg font-medium hover:bg-gray-800 transition-colors"
      >
        EXPLORE MORE
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- DESKTOP: scroll-driven con immagini scatter -->
  <!-- ═══════════════════════════════════════════ -->
  <div
    data-showcase-desktop
    class="hidden md:flex sticky top-0 h-screen flex-col items-center justify-center overflow-hidden"
  >
    <!-- Scatter images -->
    <div
      data-showcase-image
      class="absolute bottom-[5%] left-[5%] w-60 lg:w-80 aspect-video rounded-2xl bg-violet-400/60"
    >
    </div>
    <div
      data-showcase-image
      class="absolute bottom-[35%] left-[8%] w-40 lg:w-50 aspect-square rounded-2xl bg-blue-400/60"
    >
    </div>
    <div
      data-showcase-image
      class="absolute top-[10%] left-[20%] lg:left-[30%] w-32 lg:w-40 aspect-square rounded-2xl bg-indigo-400/60"
    >
    </div>
    <div
      data-showcase-image
      class="absolute top-[15%] right-[20%] lg:right-[30%] w-24 lg:w-32 aspect-square rounded-2xl bg-purple-400/60"
    >
    </div>
    <div
      data-showcase-image
      class="absolute bottom-[20%] right-[15%] lg:right-[25%] w-40 lg:w-50 aspect-video rounded-2xl bg-sky-400/60"
    >
    </div>
    <div
      data-showcase-image
      class="absolute bottom-[5%] right-[5%] w-40 lg:w-50 aspect-square rounded-2xl bg-cyan-400/60"
    >
    </div>

    <!-- Sliding image (fase 1: top-right, fase 2: nella grid) -->
    <div
      data-showcase-slider
      class="absolute top-[10%] right-[5%] w-36 lg:w-44 aspect-9/16 rounded-2xl bg-rose-400/60"
    >
    </div>

    <!-- Title + CTA (fase 1) -->
    <div data-showcase-content class="relative z-10 text-center">
      <h2
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight mb-8"
      >
        Elevate<br /> your brand with <br /> flavorful touch
      </h2>
      <a
        href="#"
        class="inline-block px-8 py-2 bg-black text-white rounded-full text-lg font-medium hover:bg-gray-800 transition-colors"
      >
        EXPLORE MORE
      </a>
    </div>

    <!-- Layout finale (fase 2) — grid 2 col con slider a sx e testo a dx -->
    <div
      data-showcase-final
      class="absolute inset-0 grid grid-cols-2 items-center gap-8 px-12 lg:px-20 z-10"
    >
      <!-- Colonna per lo slider -->
      <div></div>
      <!-- Testo -->
      <div class="text-left">
        <h3
          class="text-2xl sm:text-3xl lg:text-5xl font-bold tracking-tight mb-4 md:mb-6"
        >
          Eleganza, <br /> innovazione
        </h3>
        <p class="text-base max-w-md md:text-lg text-gray-600 leading-relaxed">
          Abbiamo trasformato l'eleganza e l'innovazione di un colosso
          dell'eyewear in un racconto visivo mozzafiato, dando vita alle
          collezioni dei brand più iconici attraverso una serie di video che
          esaltano stile, carattere e unicità
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { setupShowcase } from "./showcase.motion";

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      setupShowcase();
    });
  });
</script>
