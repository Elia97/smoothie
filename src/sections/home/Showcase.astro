---
import { Image } from "astro:assets";

import imgScatter1 from "../../assets/DSC06957_q80.webp";
import imgScatter2 from "../../assets/marepineta_q80.webp";
import imgScatter3 from "../../assets/BRUT PRESTIGE_q80.webp";
import imgScatter4 from "../../assets/58-1_q80.webp";
import imgScatter5 from "../../assets/4_q80.webp";
import imgScatter6 from "../../assets/JAPAN HOUSE_q80.webp";
import sliderVideo from "../../assets/01_9_16.mp4";
---

<section id="showcase" class="relative min-h-screen md:h-[300vh]">
  <!-- ═══════════════════════════════════════════ -->
  <!-- MOBILE: layout statico con animazioni dichiarative -->
  <!-- ═══════════════════════════════════════════ -->
  <div
    class="md:hidden flex flex-col sm:flex-row items-center justify-center min-h-screen gap-8 px-4 my-12"
  >
    <div class="mt-12">
      <h2
        data-motion="fade-in"
        class="text-3xl sm:text-4xl font-bold tracking-tight mb-8"
      >
        Elevate<br /> your brand with <br /> flavorful touch
      </h2>
      <a
        href="#"
        data-motion="fade-in"
        data-motion-delay="0.15"
        class="btn-primary"
      >
        Explore more
      </a>
    </div>
    <div
      data-motion="scale-in"
      class="w-full max-w-60 aspect-9/16 rounded-2xl overflow-hidden"
    >
      <video
        src={sliderVideo}
        autoplay
        muted
        loop
        playsinline
        class="w-full h-full object-cover"></video>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- DESKTOP: scroll-driven con immagini scatter -->
  <!-- ═══════════════════════════════════════════ -->
  <div
    data-showcase-desktop
    class="hidden md:flex sticky top-0 h-screen flex-col items-center justify-center overflow-hidden"
  >
    <!-- Scatter images -->
    <div
      data-showcase-image
      class="absolute bottom-[5%] left-[5%] w-[25vw] aspect-video rounded-2xl overflow-hidden"
    >
      <Image
        src={imgScatter1}
        alt="Showcase 1"
        width={640}
        class="w-full h-full object-cover"
      />
    </div>
    <div
      data-showcase-image
      class="absolute bottom-[45%] left-[10%] w-[15vw] aspect-square rounded-2xl overflow-hidden"
    >
      <Image
        src={imgScatter2}
        alt="Showcase 2"
        width={400}
        class="w-full h-full object-cover"
      />
    </div>
    <div
      data-showcase-image
      class="absolute top-[5%] left-[30%] w-[10vw] aspect-square rounded-2xl overflow-hidden"
    >
      <Image
        src={imgScatter3}
        alt="Showcase 3"
        width={320}
        class="w-full h-full object-cover"
      />
    </div>
    <div
      data-showcase-image
      class="absolute top-[10%] right-[40%] w-[8vw] aspect-square rounded-2xl overflow-hidden"
    >
      <Image
        src={imgScatter4}
        alt="Showcase 4"
        width={256}
        class="w-full h-full object-cover"
      />
    </div>
    <div
      data-showcase-image
      class="absolute bottom-[20%] right-[25%] w-[15vw] aspect-video rounded-2xl overflow-hidden"
    >
      <Image
        src={imgScatter5}
        alt="Showcase 5"
        width={400}
        class="w-full h-full object-cover"
      />
    </div>
    <div
      data-showcase-image
      class="absolute bottom-[5%] right-[5%] w-[15vw] aspect-square rounded-2xl overflow-hidden"
    >
      <Image
        src={imgScatter6}
        alt="Showcase 6"
        width={400}
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Sliding video (fase 1: top-right, fase 2: nella grid) -->
    <div
      data-showcase-slider
      class="absolute top-[10%] right-[5%] w-[20vw] lg:w-[12vw] aspect-9/16 rounded-2xl overflow-hidden"
    >
      <video
        src={sliderVideo}
        autoplay
        muted
        loop
        playsinline
        class="w-full h-full object-cover"></video>
    </div>

    <!-- Title + CTA (fase 1) -->
    <div data-showcase-content class="relative z-10 text-center">
      <h2
        class="text-2xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-8"
      >
        Elevate<br /> your brand with <br /> flavorful touch
      </h2>
      <a href="#" class="btn-primary">Explore more</a>
    </div>

    <!-- Layout finale (fase 2) — grid 2 col con slider a sx e testo a dx -->
    <div
      data-showcase-final
      class="absolute inset-0 grid grid-cols-2 items-center gap-8 px-12 lg:px-20 z-10"
    >
      <!-- Colonna per lo slider -->
      <div></div>
      <!-- Testo -->
      <div class="text-left">
        <h2
          class="text-2xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-8"
        >
          Eleganza, <br /> innovazione
        </h2>
        <p class="max-w-md sm:text-lg text-muted-foreground leading-relaxed">
          Abbiamo trasformato l'eleganza e l'innovazione di un colosso
          dell'eyewear in un racconto visivo mozzafiato, dando vita alle
          collezioni dei brand più iconici attraverso una serie di video che
          esaltano stile, carattere e unicità.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { setupShowcase } from "./showcase.motion";
  setupShowcase();
</script>
