---
import MarqueeTrack from "../../components/ui/MarqueeTrack.astro";
---

<section
  class="flex flex-col justify-center gap-12 md:gap-16 overflow-hidden px-4"
>
  <div class="max-w-md mx-auto text-center">
    <span
      data-motion="fade-in"
      class="text-sm sm:text-base text-center border w-fit mx-auto px-3 py-1 rounded-full mb-4 md:mb-6 block"
    >
      OUR CLIENT
    </span>
    <p
      data-motion="fade-in"
      data-motion-delay="0.15"
      class="text-center sm:text-lg max-w-sm mx-auto"
    >
      I nostri clienti, straordinari artefici di storie di successo insieme a
      noi
    </p>
  </div>

  <!-- Carousel loghi clienti — doppia riga marquee -->
  <div class="flex flex-col gap-4">
    <!-- Riga 1: scorre a sinistra -->
    <MarqueeTrack duration="30s" gap="1.5rem">
      <div class="partner-logo">Logo 1</div>
      <div class="partner-logo">Logo 2</div>
      <div class="partner-logo">Logo 3</div>
      <div class="partner-logo">Logo 4</div>
      <div class="partner-logo">Logo 5</div>
      <div class="partner-logo">Logo 6</div>
      <div class="partner-logo">Logo 7</div>
      <div class="partner-logo">Logo 8</div>
      <!-- Duplicato per loop continuo -->
      <div class="partner-logo">Logo 1</div>
      <div class="partner-logo">Logo 2</div>
      <div class="partner-logo">Logo 3</div>
      <div class="partner-logo">Logo 4</div>
      <div class="partner-logo">Logo 5</div>
      <div class="partner-logo">Logo 6</div>
      <div class="partner-logo">Logo 7</div>
      <div class="partner-logo">Logo 8</div>
    </MarqueeTrack>

    <!-- Riga 2: scorre a destra (reverse) -->
    <MarqueeTrack duration="30s" gap="1.5rem" reverse>
      <div class="partner-logo">Logo 9</div>
      <div class="partner-logo">Logo 10</div>
      <div class="partner-logo">Logo 11</div>
      <div class="partner-logo">Logo 12</div>
      <div class="partner-logo">Logo 13</div>
      <div class="partner-logo">Logo 14</div>
      <div class="partner-logo">Logo 15</div>
      <div class="partner-logo">Logo 16</div>
      <!-- Duplicato per loop continuo -->
      <div class="partner-logo">Logo 9</div>
      <div class="partner-logo">Logo 10</div>
      <div class="partner-logo">Logo 11</div>
      <div class="partner-logo">Logo 12</div>
      <div class="partner-logo">Logo 13</div>
      <div class="partner-logo">Logo 14</div>
      <div class="partner-logo">Logo 15</div>
      <div class="partner-logo">Logo 16</div>
    </MarqueeTrack>
  </div>
</section>

<style>
  .partner-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 10rem;
    height: 5rem;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: #f9fafb;
    font-weight: 500;
    color: #6b7280;
  }
</style>
