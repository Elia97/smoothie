---
import MarqueeTrack from "../../components/ui/MarqueeTrack.astro";
import { Image } from "astro:assets";
import logo1 from "../../assets/loghi/228-thelios_q80.webp";
import logo2 from "../../assets/loghi/De_Rigo_logo_q80.webp";
import logo3 from "../../assets/loghi/Escada_q80.webp";
import logo4 from "../../assets/loghi/FilaEyewear_Nero_q80.webp";
import logo5 from "../../assets/loghi/I AM Unico - Logo blu_q80.webp";
import logo6 from "../../assets/loghi/Just Cavalli Logo_q80.webp";
import logo7 from "../../assets/loghi/Logo-Casa_Sanremo_Tavola-disegno-1-copia-8_q80.webp";
import logo8 from "../../assets/loghi/logo-caveja_q80.webp";
import logo9 from "../../assets/loghi/Logo-ITALSOFT-payoff-1024x576_q80.webp";
import logo10 from "../../assets/loghi/nero_q80.webp";
import logo11 from "../../assets/loghi/Philipp_Plein_B_q80.webp";
import logo12 from "../../assets/loghi/Roberto Cavalli_no eyewear_q80.webp";
---

<section id="partner" class="flex flex-col justify-center gap-12 md:gap-16 overflow-hidden">
  <div class="max-w-md mx-auto px-8">
    <span data-motion="fade-in" class="badge">Our client</span>
    <p
      data-motion="fade-in"
      data-motion-delay="0.15"
      class="max-w-md sm:text-lg text-muted-foreground leading-relaxed mx-auto text-center"
    >
      I nostri clienti, straordinari artefici di storie di successo insieme a
      noi
    </p>
  </div>

  <!-- Carousel loghi clienti — doppia riga marquee -->
  <div class="flex flex-col gap-4">
    <!-- Riga 1: scorre a sinistra -->
    <MarqueeTrack duration="30s" gap="1.5rem">
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo1}
          alt="Thelios"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo2}
          alt="De Rigo"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo3}
          alt="Escada"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo4}
          alt="Fila Eyewear"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo5}
          alt="I AM Unico"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo6}
          alt="Just Cavalli"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <!-- Duplicato per loop continuo -->
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo1}
          alt="Thelios"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo2}
          alt="De Rigo"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo3}
          alt="Escada"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo4}
          alt="Fila Eyewear"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo5}
          alt="I AM Unico"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo6}
          alt="Just Cavalli"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
    </MarqueeTrack>

    <!-- Riga 2: scorre a destra -->
    <MarqueeTrack duration="30s" gap="1.5rem" reverse>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo7}
          alt="Casa Sanremo"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo8}
          alt="Caveja"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo9}
          alt="Italsoft"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo10}
          alt="Nero"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo11}
          alt="Philipp Plein"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo12}
          alt="Roberto Cavalli"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <!-- Duplicato per loop continuo -->
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo7}
          alt="Casa Sanremo"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo8}
          alt="Caveja"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo9}
          alt="Italsoft"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo10}
          alt="Nero"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo11}
          alt="Philipp Plein"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
      <div class="shrink-0 flex items-center justify-center w-64 h-32 p-4">
        <Image
          src={logo12}
          alt="Roberto Cavalli"
          width={240}
          class="max-w-full max-h-full object-contain opacity-50"
        />
      </div>
    </MarqueeTrack>
  </div>
</section>
