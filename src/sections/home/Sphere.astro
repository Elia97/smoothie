---
import { Image } from "astro:assets";
import sferaImage from "../../assets/sfera.webp";
---

<section id="sphere-section" class="relative h-[600vh] overflow-x-clip">
  <div class="sticky top-0 h-screen flex items-center justify-center">
    <!-- Sfera -->
    <Image
      data-sphere-orb
      src={sferaImage}
      alt=""
      role="presentation"
      width={1440}
      loading="lazy"
      class="absolute max-w-none w-[140vw] h-[140vw]"
      style="left: calc(50% - 70vw); top: calc(50% - 70vw);"
    />

    <!-- Fase 1: Badge + 4 titoli -->
    <div
      data-sphere-titles
      class="relative z-10 flex flex-col items-center gap-6 text-center px-4"
    >
      <span data-sphere-badge class="badge"> What we do </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        CONSULTANCY
      </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        CREATIVE
      </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        COMMUNICATE
      </span>
      <span
        data-sphere-keyword
        class="text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight block"
      >
        PERFORMANCE
      </span>
    </div>

    <!-- Contenuto dentro la sfera -->
    <div
      data-sphere-inner
      class="absolute z-20 flex flex-col items-center gap-4 text-center px-4 text-white"
    >
      <span class="badge border-white"> Our mission </span>
      <h2
        class="text-2xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-8"
      >
        Guidare la crescita <br /> delle aziende con <br /> innovazione, creatività
        <br /> e tecnologia
      </h2>
    </div>

    <!-- Titolo finale + CTA (parte 3, specchiata) -->
    <div
      data-sphere-cta
      class="absolute z-10 flex flex-col items-center gap-6 text-center px-4"
    >
      <p
        class="text-3xl sm:text-5xl lg:text-6xl font-bold text-center leading-snug tracking-tight"
      >
        Ready to shake <br /> things up?
      </p>
      <a href="/contact" class="btn-primary"
        >Contact us</a
      >
    </div>
  </div>
</section>

<script>
  import { setupSphere } from "./sphere.motion";
  setupSphere();
</script>
