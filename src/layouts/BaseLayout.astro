---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Smoothie",
  description = "Smoothie — il giusto mix che ridefinisce i confini del tuo brand.",
} = Astro.props;
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/unv8try.css" />
    <title>{title}</title>
    <style>
      /* Anti-FOUC: elementi motion nascosti fino a init GSAP.
         GSAP autoAlpha li rivela (visibility:visible + opacity:1). */
      [data-motion],
      [data-motion-item],
      [data-cursor-target],
      [data-showcase-image],
      [data-showcase-slider],
      [data-showcase-final],
      [data-sphere-keyword],
      [data-sphere-inner],
      [data-sphere-cta],
      [data-hero-title],
      [data-hero-header],
      [data-hero-scroll-hint] {
        visibility: hidden;
      }
    </style>
  </head>
  <body>
    <noscript>
      <style>
        [data-motion],
        [data-motion-item],
        [data-cursor-target],
        [data-showcase-image],
        [data-showcase-slider],
        [data-showcase-final],
        [data-sphere-keyword],
        [data-sphere-inner],
        [data-sphere-cta],
        [data-hero-title],
        [data-hero-header],
        [data-hero-scroll-hint] {
          visibility: visible !important;
        }
        #page-loader {
          display: none !important;
        }
      </style>
    </noscript>
    <slot />
  </body>
</html>
